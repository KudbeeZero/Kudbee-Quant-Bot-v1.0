__pycache__/
*.pyc
*.egg-info/
.cache/
*.parquet
# Node toolchain for the Tailwind build — only the compiled assets/css/app.css
# (and kudbee_quant/static/app.css) are committed; node_modules is regenerable.
node_modules/
# Wrangler local cache (account id/name, build artifacts) — regenerable, machine-local.
.wrangler/
# Wrangler dev secrets — never commit (worker secrets live in Cloudflare, not the repo).
.dev.vars
.dev.vars.*
# Agent worktrees (transient, auto-cleaned; created by isolated subagents)
.claude/worktrees/
# Overnight research runtime cache + loop log (regenerable; not source)
data/_overnight_cache/
.venv/
# Secrets — never commit. Loaded from the environment only.
.env
.env.*
!.env.example
*.key
*.pem
secrets.json
# AI chart review runtime data (operator uploads + AI reads; ephemeral on Render,
# consistent with the other derived data files). The schema lives in the code.
data/chart_images/*
!data/chart_images/.gitkeep
data/chart_reviews.json

# Tier-1 shadow-overlay run artifacts (generated; never committed)
data/shadow/

# Daily trade graph — generated SVG (derived from the bot-owned journal; never committed)
data/daily_graph.svg

# Journal report snapshots (scripts/journal_report.py output; generated, races the bot)
data/reports/

# Graphify knowledge-graph output (if trialed) — never commit (incl. cost.json)
graphify-out/

# Tiered exit comparison snapshots (generated)
kudbee_quant/backtest/results/
