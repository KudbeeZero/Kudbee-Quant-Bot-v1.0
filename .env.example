# Kudbee Quant — environment template. Copy to `.env` (gitignored) and fill in.
# NEVER commit real secrets. Every value below is optional; defaults are safe.

# --- AI Chart Review (dashboard-only feature; default OFF) -------------------
# Turn the chart-review endpoints on. Default false -> endpoints return 503.
ENABLE_AI_CHART_REVIEW=false
# OpenAI key for the server-side vision call. Read server-side only; never sent
# to the browser. Without it, the endpoint is disabled (503).
OPENAI_API_KEY=
# Vision model used for chart review (default: gpt-4o).
OPENAI_CHART_REVIEW_MODEL=gpt-4o

# --- Dashboard auth (see kudbee_quant/api_auth.py) ---------------------------
# Password for /login; without it, login is disabled (503).
KUDBEE_DASHBOARD_PASSWORD=
# Optional dedicated key for signing session cookies (falls back if unset).
KUDBEE_SESSION_SECRET=

# --- Write API auth (see kudbee_quant/api_security.py) -----------------------
# Token for write endpoints (/api/alert, /api/paper/scan); unset -> writes 503.
KUDBEE_API_TOKEN=
# Comma-separated allowed CORS origins for the site (unset -> permissive dev).
KUDBEE_SITE_ORIGIN=

# --- Live execution double-gate (see kudbee_quant/config/runtime.py) ---------
# BOTH must be set for any real order. Leave as-is to stay in paper mode.
TRADING_MODE=paper
ENABLE_LIVE_EXECUTION=false

# --- Telegram notifications (see docs/NOTIFICATIONS.md) -----------------------
# Optional. Unset -> the whole notification layer is a silent no-op. Set BOTH to
# get pings on new setups + resolved trades and an hourly portfolio summary from
# the paper-trade Action (add the same two as GitHub repo secrets for CI).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional kill-switch: set to 0/false/no/off to mute even with creds present.
KUDBEE_TELEGRAM_ENABLED=
# Two-way command webhook (/api/telegram): shared secret registered with Telegram
# via setWebhook?secret_token=... and verified on every POST (X-Telegram-Bot-Api-
# Secret-Token header). Unset => the webhook returns 403 (commands disabled).
TELEGRAM_WEBHOOK_SECRET=

# --- TR Level Intelligence (Cloudflare D1; see kudbee_quant/intelligence/) ----
# Optional. Persists build_levels() output + unrecovered PVSRA vectors to D1, and
# powers /levels /history /vectors in Telegram. Unset -> the intelligence layer is
# a silent no-op (it is wrapped in try/except and never blocks a scan). Set all
# three to enable. CF_API_TOKEN: a Cloudflare API token scoped to D1 edit; create
# the DB with `wrangler d1 create kudbee-tr-levels` and paste its id below.
CF_ACCOUNT_ID=
CF_API_TOKEN=
D1_DATABASE_ID=
