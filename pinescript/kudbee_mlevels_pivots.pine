//@version=5
// =============================================================================
// Kudbee Quant — M-Levels & Pivots
//
// Reference-level grid: daily/weekly/monthly opens, ADR/AWR/AMR bands, classic
// floor pivots (PP/R1-3/S1-3) from the prior COMPLETE period, and the
// Traders-Reality 6-level M-grid (M0-M5, the midpoints between floor pivots).
// Mirrors kudbee_quant/levels/builder.py (build_levels / MLEVEL_COLUMNS) —
// same formulas, computed here directly from request.security so the chart
// never needs the Python engine to show the grid.
//
// CAUSALITY: every level is built from the PRIOR completed day/week/month
// (request.security's default lookahead_off + [1] history-referencing), so
// nothing here ever previews an in-progress period's own range.
// =============================================================================
indicator("Kudbee M-Levels & Pivots", overlay=true, max_lines_count=200, max_labels_count=100)

showOpens  = input.bool(true,  "Daily/weekly/monthly opens", group="Opens")
showRange  = input.bool(true,  "ADR/AWR/AMR bands",          group="Range bands")
adrLen     = input.int(14, "ADR lookback (days)",  minval=1, group="Range bands")
awrLen     = input.int(8,  "AWR lookback (weeks)",  minval=1, group="Range bands")
amrLen     = input.int(6,  "AMR lookback (months)", minval=1, group="Range bands")
showPivots = input.bool(true,  "Floor pivots (PP/R/S 1-3)",  group="Pivots")
showMLevels= input.bool(true,  "M-level grid (M0-M5)",       group="Pivots")
extendBars = input.int(48, "Level line length (bars)", minval=1, group="Display")

// ---- Reference opens ---------------------------------------------------------
dOpen = request.security(syminfo.tickerid, "D", open, lookahead=barmerge.lookahead_off)
wOpen = request.security(syminfo.tickerid, "W", open, lookahead=barmerge.lookahead_off)
mOpen = request.security(syminfo.tickerid, "M", open, lookahead=barmerge.lookahead_off)

plot(showOpens ? dOpen : na, "Daily Open",   color.new(color.yellow, 0),  1, plot.style_linebr)
plot(showOpens ? wOpen : na, "Weekly Open",  color.new(color.orange, 0),  2, plot.style_linebr)
plot(showOpens ? mOpen : na, "Monthly Open", color.new(color.red, 0),     2, plot.style_linebr)

// ---- ADR / AWR / AMR bands (prior N FULL periods, excludes current) --------
adr = request.security(syminfo.tickerid, "D", ta.sma(high - low, adrLen)[1], lookahead=barmerge.lookahead_off)
awr = request.security(syminfo.tickerid, "W", ta.sma(high - low, awrLen)[1], lookahead=barmerge.lookahead_off)
amr = request.security(syminfo.tickerid, "M", ta.sma(high - low, amrLen)[1], lookahead=barmerge.lookahead_off)

plot(showRange ? dOpen + adr : na, "ADR High", color.new(color.gray, 40), 1)
plot(showRange ? dOpen - adr : na, "ADR Low",  color.new(color.gray, 40), 1)
plot(showRange ? wOpen + awr : na, "AWR High", color.new(color.teal, 55), 1)
plot(showRange ? wOpen - awr : na, "AWR Low",  color.new(color.teal, 55), 1)
plot(showRange ? mOpen + amr : na, "AMR High", color.new(color.maroon, 55), 1)
plot(showRange ? mOpen - amr : na, "AMR Low",  color.new(color.maroon, 55), 1)

// ---- Classic floor pivots, prior COMPLETE NY day (via request.security[1]) --
pdh = request.security(syminfo.tickerid, "D", high[1],  lookahead=barmerge.lookahead_off)
pdl = request.security(syminfo.tickerid, "D", low[1],   lookahead=barmerge.lookahead_off)
pdc = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_off)

pp = (pdh + pdl + pdc) / 3.0
r1 = 2 * pp - pdl
s1 = 2 * pp - pdh
r2 = pp + (pdh - pdl)
s2 = pp - (pdh - pdl)
r3 = pdh + 2 * (pp - pdl)
s3 = pdl - 2 * (pdh - pp)

// ---- M-level grid: midpoints between adjacent floor pivots -------------------
m5 = (r2 + r3) / 2.0
m4 = (r1 + r2) / 2.0
m3 = (pp + r1) / 2.0
m2 = (s1 + pp) / 2.0
m1 = (s2 + s1) / 2.0
m0 = (s3 + s2) / 2.0

// ---- Trailing line + label per level, endpoints updated in place each bar
// (no delete/recreate churn) so each pivot tracks its current value live and
// only moves when the underlying prior-period close actually changes it.
f_level(showIt, y, txt, col, w) =>
    var line  l = na
    var label lb = na
    if showIt
        if na(l)
            l := line.new(bar_index, y, bar_index + extendBars, y, color=col, width=w, style=line.style_dashed)
            lb := label.new(bar_index + extendBars, y, txt, style=label.style_label_left, textcolor=col, color=color.new(color.black, 100), size=size.tiny)
        else
            line.set_xy1(l, bar_index, y)
            line.set_xy2(l, bar_index + extendBars, y)
            label.set_xy(lb, bar_index + extendBars, y)
    else if not na(l)
        line.delete(l)
        label.delete(lb)
        l := na
        lb := na

f_level(showPivots, pp, "PP",  color.new(color.orange, 10), 2)
f_level(showPivots, r1, "R1",  color.new(color.red, 20), 1)
f_level(showPivots, r2, "R2",  color.new(color.red, 35), 1)
f_level(showPivots, r3, "R3",  color.new(color.red, 50), 1)
f_level(showPivots, s1, "S1",  color.new(color.green, 20), 1)
f_level(showPivots, s2, "S2",  color.new(color.green, 35), 1)
f_level(showPivots, s3, "S3",  color.new(color.green, 50), 1)

f_level(showMLevels, m5, "M5", color.new(color.maroon, 30), 1)
f_level(showMLevels, m4, "M4", color.new(color.maroon, 45), 1)
f_level(showMLevels, m3, "M3", color.new(color.gray, 20), 1)
f_level(showMLevels, m2, "M2", color.new(color.gray, 20), 1)
f_level(showMLevels, m1, "M1", color.new(color.teal, 45), 1)
f_level(showMLevels, m0, "M0", color.new(color.teal, 30), 1)
